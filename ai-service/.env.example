# =============================================================
# AssetGuardian AI Service — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git!
# =============================================================

# Server binding (cloud platforms inject PORT automatically)
HOST=0.0.0.0
PORT=8000

# Allowed callers — comma-separated
ALLOWED_ORIGINS=https://your-backend.onrender.com,https://your-frontend.vercel.app
